// ==========================================
// 🛠️ 系统配置 (Configuration)
// ==========================================

generator client {
  provider = "prisma-client-js"
}

// Vercel 部署时 DATABASE_URL 必须用 Supabase 连接池（Transaction 模式，端口 6543），并在末尾加 ?pgbouncer=true。详见 docs/vercel.md
datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ==========================================
// 🔐 权限与角色 (Auth Enums)
// ==========================================

enum Role {
  ADMIN // 总部管理员 (公司员工)
  OWNER // 俱乐部负责人 (道场馆长)
}

enum ApplicationStatus {
  pending   // 未处理
  contacted // 已联系
  joined    // 已入会
  rejected  // 已取消/拒绝
}

// ==========================================
// 👤 用户系统 (Users)
// ==========================================

model User {
  id        String   @id // 建议对接 Auth 系统的 ID
  email     String   @unique
  name      String?
  role      Role     @default(OWNER)

  // 馆长关联的俱乐部 (一对多关系)
  // 如果您希望一个用户只能拥有一个俱乐部，请去掉 [] 并将 clubId 移回 User 表
  // 但既然您之前的 Schema 里 User.clubId 是 unique 的，那我们保持一对一关系更简单：
  // 修正方案：保持 User.clubId 作为外键可能导致循环依赖，通常做法是 Club.ownerId 作为外键。
  // 下面采用标准的【一个 User 拥有多个 Club】的写法，兼容性最强：
  clubs     Club[]   @relation("ClubOwner")

  // 发布记录
  activities Activity[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==========================================
// 🏛️ 俱乐部核心资产 (Clubs)
// ==========================================

model Club {
  id             String    @id @default(cuid())
  name           String
  nameEn         String? // EN site display; fallback to name when empty
  slug           String    @unique
  description    String?   @db.Text
  descriptionEn  String?   @db.Text
  logo           String?
  mainImage          String?
  mainImagePosition  String?  // 卡片封面焦点 "x,y" (0-100)，缺省为 "50,50"
  mainImageScale     Float?   // 封面缩放 1.0–4.0，缺省为 1.0
  mainImageRotation  Int?     // 旋转角度 0/90/180/270，缺省为 0
  subImages          String[] // 副图数组

  // 所在地信息
  zipCode        String?   // 郵便番号
  area           String    // 都道府県 (必须)
  city           String?   // 市区町村
  address        String    // 番地 (必须)
  mapUrl         String?   @db.Text // Google Maps 链接

  // 联络信息
  phone          String?
  email          String?
  website        String?
  instagram      String?
  twitter        String?
  tiktok         String?
  facebook       String?
  /// 访客向けに電話番号を表示するか（DB の phone は保持し、同意取得後にのみ true）
  phoneVisibleOnPublicSite Boolean @default(false)

  // 运营信息
  schedule       String?   // 稽古时间 (JSON String)
  target         String?   // 募集对象
  representative String?   // 代表者

  // 关系链路：所有权
  ownerId        String?   // 允许为空，因为可能有俱乐部暂时没有分配 owner
  owner          User?     @relation("ClubOwner", fields: [ownerId], references: [id])

  // 其他关系
  activities     Activity[]
  applications   Application[] // 关联的申请记录
  hidden         Boolean   @default(false) // 非表示時、前台には表示・検索されない
  published      Boolean   @default(false) // 默认为 false (草稿状态)
  homePickup     HomePickupClub? // 首页「注目の相撲クラブ」槽位（最多 3 个）
  prefectureBannerFeatured PrefectureBanner[] @relation("PrefectureBannerFeaturedClub")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([area]) // 优化按地区查询的性能
  @@index([name]) // 优化搜索性能
}

// ==========================================
// 📝 内容与活动 (Activities / News)
// ==========================================

model Activity {
  id           String   @id @default(cuid())
  title        String
  titleEn      String?
  slug         String   @unique
  date         DateTime
  location     String?
  category     String   @default("Report")
  mainImage    String?
  published    Boolean  @default(true)

  // 模版分发逻辑
  templateType String   @default("news") // news, report, event, custom
  contentData  Json?    // 结构化积木数据
  content      String?  @db.Text // 纯文本备份 (SEO 优化)
  contentEn    String?  @db.Text // optional EN body when blocks are not translated

  // 归属信息
  clubId       String
  club         Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  authorId     String
  author       User     @relation(fields: [authorId], references: [id])

  customRoute  String?  // 手写精装页面的路由 ID

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([clubId])
  @@index([category])
  @@index([title]) // 优化搜索性能
  @@index([date])  // 优化排序性能
}

// ==========================================
// 📚 数字化资产 (Magazines & Banners)
// ==========================================

model Magazine {
  id          String   @id @default(cuid())
  title       String   // 杂志标题，如：相扑月刊 Vol.15
  /// 英文标题（可选）；英文站优先，空则回退 title
  titleEn     String?
  slug        String   @unique // 用于 URL 的唯一标识
  description String?  @db.Text // 简短描述或本期看点
  /// 英文简介（可选）；英文站优先，空则回退 description
  descriptionEn String? @db.Text
  region      String   @default("All") // 用于地区筛选 (例如：全国, 関東, 関西)
  coverImage  String?  // 封面图 URL
  images      String[] //内页图片数组
  pdfUrl      String?  // PDF 文件下载链接
  readLink    String?  // 在线阅读链接（如果使用的是外部翻页工具）
  
  issueDate   DateTime @default(now()) // 杂志所属的期数日期
  published   Boolean  @default(true)  // 发布状态开关
  hidden      Boolean  @default(false) // 非表示（前台から隠す、データは保持）
  /// ltr = 右開き（左→右にめくる） / rtl = 左開き（右→左にめくる）
  readingDirection String @default("ltr")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([issueDate]) // 为日期添加索引，提高列表查询性能
  @@index([region]) // 为筛选字段添加索引
  @@index([title])  // 优化搜索性能
}

enum BannerCategory {
  club     // 俱乐部
  sponsor  // 赞助商
}

// 赞助商等级：高級（OFFICIAL TOP PARTNER）/ 低级（LOCAL SUPPORTER）
enum BannerSponsorTier {
  OFFICIAL
  LOCAL
}

// 各页面旗子显示模式：全部 / 仅俱乐部 / 仅赞助商 / 混合(先俱乐部后赞助商)
enum BannerDisplayMode {
  all
  club
  sponsor
  mixed
}

model Banner {
  id          String              @id @default(cuid())
  name        String
  image       String
  alt         String?
  link        String?
  category    BannerCategory      @default(club)
  sponsorTier BannerSponsorTier?  @default(LOCAL) // 仅 category=sponsor 时使用；未定时默认 LOCAL，确定后再可改为 OFFICIAL
  sortOrder   Int                 @default(0)
  isActive    Boolean             @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
}

// 都道府県ページの Feature Banner（クラブ画像 or 占位图）
model PrefectureBanner {
  id             String   @id @default(cuid())
  pref           String   @unique // 都道府県 slug (例: iwate, tokyo)
  image          String   // 画像 URL (Supabase 或 /images/banner/...)
  alt            String?  // 画像の説明（例：〇〇県の相撲風景）
  imagePosition  String?  @default("50,50") // "x,y" 百分比，与 Club 一致
  imageScale     Float?   @default(1) // 1–4，与 Club 一致
  imageRotation  Int?     // 旋转角度 0/90/180/270，缺省为 0
  // 「〇〇の相撲風景」で紹介するクラブ（未設定時は写真ありクラブを優先して自動）
  featuredClubId String?
  featuredClub   Club?    @relation("PrefectureBannerFeaturedClub", fields: [featuredClubId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([pref])
  @@index([featuredClubId])
}

// 旗子在各页面的显示设置（单例，供后台「显示设置」使用）
// 各位置的 sponsorTierFilter: "all" | "official_only" | "local_only"（全部 / 高級のみ / 低级のみ）
model BannerDisplaySetting {
  id                        String             @id @default("default")
  homeDisplayMode           BannerDisplayMode  @default(mixed)
  homeSponsorTierFilter     String             @default("all")
  prefTopDisplayMode        BannerDisplayMode  @default(mixed)
  prefTopSponsorTierFilter  String             @default("all")
  prefSidebarDisplayMode    BannerDisplayMode  @default(mixed)
  prefSidebarSponsorTierFilter String          @default("all")
  updatedAt                 DateTime           @updatedAt
}

// 首页「注目の相撲クラブ」显示的 3 个俱乐部（按顺序 1 / 2 / 3）
// 未配置或某槽位俱乐部被删除时，首页回退为「最新 3 件」
model HomePickupClub {
  sortOrder Int     @unique // 0, 1, 2 对应左 / 中 / 右
  clubId    String? @unique // 一个俱乐部最多出现在一个槽位
  club      Club?   @relation(fields: [clubId], references: [id], onDelete: SetNull)
}

// ==========================================
// 👁️ 预览草稿 (Preview Draft - 未保存内容临时存储)
// ==========================================
// 管理画面「プレビュー」用。Serverless 下内存不共享，改用 DB 存储。
// TTL 5 分钟，由查询时检查 expiresAt 清理。
model PreviewDraft {
  id           String   @id @default(cuid())
  previewId    String   @unique // 8 位短 ID，用于 cookie/URL
  type         String   // club, banner_single, prefecture_banner, etc.
  path         String   // 目标路径如 /clubs/osaka-sumo
  payload      Json     // 预览数据
  expiresAt    DateTime

  @@index([previewId])
  @@index([expiresAt])
}

// ==========================================
// 📩 业务转化：入会申请 (Applications)
// ==========================================

model Application {
  id         String            @id @default(cuid())
  
  // 关联道场
  clubId     String
  club       Club              @relation(fields: [clubId], references: [id], onDelete: Cascade)
  clubName   String            // 冗余存储，防止道场改名后找不到历史记录

  // 申请人信息
  name       String
  email      String
  phone      String?
  experience String            // beginner, experienced
  message    String?           @db.Text
  
  // 状态管理 (使用 Enum 确保类型安全)
  status     ApplicationStatus @default(pending)

  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  @@index([clubId])
  @@index([status])
  @@index([createdAt]) // 优化排序性能
}

// ==========================================
// 📬 通用询问 (Contact Form Inquiries)
// ==========================================

enum InquiryStatus {
  unread    // 未読
  read      // 確認済み
  replied   // 返信済み
  closed    // 対応完了
}

model Inquiry {
  id           String        @id @default(cuid())
  
  // 询问人信息
  name         String        // お名前
  furigana     String?       // フリガナ
  email        String        // メールアドレス
  phone        String?       // 電話番号
  
  // 询问内容
  inquiryType  String        // お問い合わせ種別
  message      String        @db.Text // お問い合わせ内容
  
  // 状态管理
  status       InquiryStatus @default(unread)

  // 返信记录
  repliedAt      DateTime?
  lastReplyBody  String?     @db.Text

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([status])
  @@index([createdAt])
}